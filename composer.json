{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": ["framework", "laravel"],
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "ext-dom": "*",
        "ext-openssl": "*",
        "firebase/php-jwt": "^6.4",
        "google/apiclient": "2.13.0",
        "googleads/google-ads-php": "^17.1",
        "guzzlehttp/guzzle": "^7.2",
        "inertiajs/inertia-laravel": "^0.6.8",
        "itsgoingd/clockwork": "^5.1",
        "laravel/framework": "^10.10",
        "laravel/horizon": "^5.12.0",
        "laravel/sanctum": "^3.2",
        "laravel/socialite": "^5.5",
        "laravel/tinker": "^2.8",
        "longman/telegram-bot": "^0.77.1",
        "pestphp/pest": "^2.0",
        "pestphp/pest-plugin-laravel": "^2.0",
        "phpoffice/phpspreadsheet": "^1.23",
        "pkpass/pkpass": "^2.1",
        "psr/simple-cache": "^2.0",
        "sentry/sentry-laravel": "^3.1",
        "socialiteproviders/yandex": "^4.1",
        "spatie/crawler": "^7.1",
        "spatie/laravel-data": "^2.2",
        "spatie/laravel-settings": "^2.6",
        "staudenmeir/eloquent-has-many-deep": "^1.17",
        "symfony/dom-crawler": "^6.1",
        "symfony/panther": "^2.0",
        "tightenco/ziggy": "^1.5",
        "doctrine/dbal": "^3.0"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "dev-master",
        "barryvdh/laravel-ide-helper": "^2.12",
        "dbrekelmans/bdi": "^1.0",
        "driftingly/rector-laravel": "^0.14.2",
        "fakerphp/faker": "^1.9.1",
        "jetbrains/phpstorm-attributes": "^1.0",
        "laravel/breeze": "^1.9",
        "laravel/pint": "^1.0",
        "laravel/sail": "^1.18",
        "mockery/mockery": "^1.4.4",
        "nunomaduro/collision": "^7.0",
        "rector/rector": "^0.15.10",
        "spatie/laravel-ignition": "^2.0",
        "squizlabs/php_codesniffer": "3.*"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Module\\": "module/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/",
            "Reviews\\": "packages/reviews/src",
            "SocialWidget\\": "packages/social-widget/src",
            "Loyalty\\": "packages/loyalty/src"
        },
        "files": [
            "app/Macros/queryBuilder.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true,
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
