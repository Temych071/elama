# ----------------------------------------------------------------------
# | Config file for example.com host                                   |
# ----------------------------------------------------------------------
#
# This file is a template for an Nginx server.
# This Nginx server listens for the `example.com` host and handles requests.
# Replace `example.com` with your hostname before enabling.

# Choose between www and non-www, listen on the wrong one and redirect to
# the right one.
# https://www.nginx.com/resources/wiki/start/topics/tutorials/config_pitfalls/#server-name-if
server {
  listen [::]:443 ssl http2;
  listen 443 ssl http2;

  server_name www.{{ http_host }};

  include h5bp/tls/ssl_engine.conf;
  include h5bp/tls/policy_balanced.conf;

  ssl_certificate /etc/letsencrypt/live/{{ http_host }}/fullchain.pem;
  ssl_certificate_key /etc/letsencrypt/live/{{ http_host }}/privkey.pem;

  return 301 $scheme://{{ http_host }}$request_uri;
}


server {
  # listen [::]:443 ssl http2 accept_filter=dataready;  # for FreeBSD
  # listen 443 ssl http2 accept_filter=dataready;  # for FreeBSD
  listen [::]:443 ssl http2;
  listen 443 ssl http2;

  # The host name to respond to
  server_name {{ http_host }};

  include h5bp/tls/ssl_engine.conf;
  include h5bp/tls/policy_balanced.conf;

  ssl_buffer_size 1400; # 1400 bytes to fit in one MTU

  ssl_certificate /etc/letsencrypt/live/{{ http_host }}/fullchain.pem;
  ssl_certificate_key /etc/letsencrypt/live/{{ http_host }}/privkey.pem;

  # Path for static files
  root /var/www/ads/public;
  index index.php index.htm index.html;

  location / {
    try_files $uri $uri/ /index.php?$query_string;
  }

  charset utf-8;

  add_header X-Frame-Options "SAMEORIGIN";
  add_header X-Content-Type-Options "nosniff";

  # Custom error pages
  include h5bp/errors/custom_errors.conf;

  # Include the basic h5bp config set
  include h5bp/basic.conf;

  location = /favicon.ico { access_log off; log_not_found off; }
  location = /robots.txt  { access_log off; log_not_found off; }

  location ~ \.php$ {
      fastcgi_pass unix:/var/run/php/php8.1-fpm.sock;
      fastcgi_param SCRIPT_FILENAME $realpath_root$fastcgi_script_name;
      include fastcgi_params;
  }

  location ~ /\.(?!well-known).* {
      deny all;
  }
}
